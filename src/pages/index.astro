---
import Layout from "../layouts/Layout.astro";

const email = "kuarahylabs@gmail.com";
---

<Layout
  title="Kuarahy Labs — Solo app studio"
  description="Kuarahy Labs is a solo app studio building small, well-crafted apps. Currently shipping PawRecord, a pet health logbook."
>
  <header class="hero">
    <div class="container hero-inner">
      <img src="/logo.png" alt="Kuarahy Labs logo" class="hero-logo" width="88" height="88" />
      <p class="eyebrow">Kuarahy Labs</p>
      <h1>
        <span data-lang="en">Small studio. Sun-bright software.</span>
        <span data-lang="es">Pequeño estudio. Software brillante como el sol.</span>
      </h1>
      <p class="hero-tagline">
        <span data-lang="en"
          >A solo app studio building focused, well-made apps — one problem at
          a time.</span
        >
        <span data-lang="es"
          >Un estudio de una sola persona que hace apps simples y bien hechas,
          un problema a la vez.</span
        >
      </p>
    </div>
    <div class="sunburst" aria-hidden="true"></div>
  </header>

  <section id="apps" class="container">
    <p class="eyebrow">
      <span data-lang="en">Apps</span>
      <span data-lang="es">Apps</span>
    </p>
    <h2>PawRecord</h2>
    <div class="app-card card">
      <img
        src="/pawrecord-icon.svg"
        alt="PawRecord app icon"
        class="app-icon"
        width="72"
        height="72"
      />
      <div>
        <h3>
          <span data-lang="en">Your pet's health, in one place</span>
          <span data-lang="es">La salud de tu mascota, en un solo lugar</span>
        </h3>
        <p>
          <span data-lang="en"
            >PawRecord is a simple logbook for your pet's health — vet visits,
            vaccinations, medications, and weight, tracked in one place so
            nothing gets lost between appointments. Available for iOS and
            Android.</span
          >
          <span data-lang="es"
            >PawRecord es una libreta simple para la salud de tu mascota:
            visitas al veterinario, vacunas, medicamentos y peso, todo en un
            solo lugar para que no se te pierda nada entre citas. Disponible
            para iOS y Android.</span
          >
        </p>
        <a
          class="button"
          href="#"
          aria-disabled="true"
          data-en-label="PawRecord on Google Play — coming soon"
          data-es-label="PawRecord en Google Play, próximamente"
          aria-label="PawRecord on Google Play — coming soon"
        >
          <span data-lang="en">Coming soon to Google Play</span>
          <span data-lang="es">Próximamente en Google Play</span>
        </a>
      </div>
    </div>
  </section>

  <section id="about" class="container">
    <p class="eyebrow">
      <span data-lang="en">About</span>
      <span data-lang="es">Acerca de</span>
    </p>
    <h2>
      <span data-lang="en">Built by one person, end to end</span>
      <span data-lang="es">Hecho por una sola persona, de principio a fin</span>
    </h2>
    <p class="about-copy">
      <span data-lang="en"
        >Kuarahy Labs is a solo app studio — one developer designing,
        building, and shipping every app from scratch. The name comes from
        "kuarahy," the Guaraní word for sun: small, warm, useful software,
        made with care rather than committee.</span
      >
      <span data-lang="es"
        >Kuarahy Labs es un estudio de una sola persona: un solo desarrollador
        que diseña, construye y publica cada app de principio a fin. El
        nombre viene de "kuarahy", la palabra guaraní para sol: software
        chico, cálido y útil, hecho con cariño y no en comité.</span
      >
    </p>
  </section>

  <section id="contact" class="container">
    <p class="eyebrow">
      <span data-lang="en">Contact</span>
      <span data-lang="es">Contacto</span>
    </p>
    <h2>
      <span data-lang="en">Get in touch</span>
      <span data-lang="es">Hablemos</span>
    </h2>
    <p>
      <a href={`mailto:${email}`}>{email}</a>
    </p>
  </section>

  <footer class="container">
    <p>&copy; {new Date().getFullYear()} Kuarahy Labs.</p>
  </footer>

  <style>
    .hero {
      position: relative;
      overflow: hidden;
      padding-block: clamp(4rem, 12vw, 8rem) clamp(3rem, 8vw, 6rem);
      text-align: center;
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    .hero-logo {
      margin-bottom: 1rem;
    }

    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.25rem);
      margin: 0.25rem 0 0.5rem;
    }

    .hero-tagline {
      max-width: 32rem;
      color: var(--color-text-muted);
      font-size: 1.125rem;
    }

    .sunburst {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 140vw;
      aspect-ratio: 1;
      transform: translate(-50%, -55%);
      background: conic-gradient(
        from 0deg,
        var(--amber-light) 0deg 8deg,
        transparent 8deg 20deg
      );
      opacity: 0.35;
      z-index: 0;
      mask-image: radial-gradient(circle, black 0%, transparent 60%);
    }

    .app-card {
      display: flex;
      gap: 1.5rem;
      align-items: flex-start;
      margin-top: 1.5rem;
    }

    .app-icon {
      border-radius: 18px;
      flex-shrink: 0;
    }

    .app-card h3 {
      margin-top: 0;
    }

    .about-copy {
      max-width: 40rem;
      font-size: 1.0625rem;
    }

    footer {
      padding-block: 2rem 3rem;
      color: var(--color-text-muted);
      font-size: 0.875rem;
    }

    @media (max-width: 32rem) {
      .app-card {
        flex-direction: column;
        align-items: center;
        text-align: center;
      }
    }
  </style>
</Layout>
